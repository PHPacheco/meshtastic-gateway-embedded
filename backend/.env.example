DATABASE_URL=postgresql://user:password@host:5432/database

# Prefer RABBITMQ_URL for hosted brokers such as CloudAMQP.
# Example format: amqps://user:password@host/vhost
RABBITMQ_URL=

# Use these fields only when RABBITMQ_URL is empty.
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_USE_TLS=false
RABBITMQ_EXCHANGE=mesh_gateway
RABBITMQ_EVENTS_QUEUE=gateway_events
RABBITMQ_TELEGRAM_TO_MESHTASTIC_QUEUE=telegram_to_meshtastic
